<Window x:Class="S3_Lab6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:S3_Lab6.ViewModel"
        Title="Zarządzanie Pływakami" Height="450" Width="800">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <DataGrid x:Name="DgdPlywacy" ItemsSource="{Binding Plywacy}" 
                  SelectedItem="{Binding SelectedPlywak}"
                  AutoGenerateColumns="True" Margin="10,10,10,60"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10">
            <Button Content="Pobierz" Command="{Binding LoadCommand}" Width="80" Margin="5"/>
            <Button Content="Dodaj" Command="{Binding AddCommand}" Width="80" Margin="5"/>
            <Button Content="Usuń" Command="{Binding DeleteCommand}" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>